<Window
    x:Class="SmartFileRenameWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmartFileRenameWinUI"
    Title="Smart File Renamer">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: File Lists -->
        <Grid Grid.Row="0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Subtitle Panel -->
            <Border Grid.Column="0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Subtitles"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>

                    <Grid Grid.Row="1" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ListView x:Name="subtitleListView" Grid.Column="0"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  DragOver="SubtitleListView_DragOver"
                                  Drop="SubtitleListView_Drop"
                                  KeyDown="SubtitleListView_KeyDown"
                                  LostFocus="SubtitleListView_LostFocus"/>

                        <StackPanel Grid.Column="1" Orientation="Vertical"
                                    VerticalAlignment="Center" Spacing="4">
                            <Button Content="T" Click="SubtitleMoveTop_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move to Top"/>
                            <Button Content="U" Click="SubtitleMoveUp_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move Up"/>
                            <Button Content="D" Click="SubtitleMoveDown_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move Down"/>
                            <Button Content="B" Click="SubtitleMoveBottom_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move to Bottom"/>
                        </StackPanel>
                    </Grid>

                    <!-- Filter row -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                        <TextBox x:Name="subtitleFilterBox"
                                 PlaceholderText="Filter..." Width="120"/>
                        <Button Content="Filter" Click="SubtitleFilterButton_Click"/>
                        <Button Content="Auto" Click="SubtitleAutoFilter_Click"/>
                        <TextBlock x:Name="subtitleFileCount" Text="0 file(s)"
                                   VerticalAlignment="Center" Margin="8,0"/>
                    </StackPanel>

                    <!-- Actions row -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4">
                        <CheckBox x:Name="subtitleAutoSort" Content="Auto Sort"
                                  Checked="SubtitleAutoSort_Changed"
                                  Unchecked="SubtitleAutoSort_Changed"/>
                        <Button Content="Sort" Click="SubtitleSort_Click"/>
                        <Button Content="+File" Click="SubtitleAddFile_Click"/>
                        <Button Content="+Folder" Click="SubtitleAddFolder_Click"/>
                        <Button Content="&#x2212;" Click="SubtitleRemoveEntry_Click"
                                Width="32" ToolTipService.ToolTip="Remove selected"/>
                        <Button Content="&#x2715;" Click="SubtitleClear_Click"
                                Width="32" ToolTipService.ToolTip="Clear all"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Movie Panel -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Movies"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>

                    <Grid Grid.Row="1" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ListView x:Name="movieListView" Grid.Column="0"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  DragOver="MovieListView_DragOver"
                                  Drop="MovieListView_Drop"
                                  KeyDown="MovieListView_KeyDown"
                                  LostFocus="MovieListView_LostFocus"/>

                        <StackPanel Grid.Column="1" Orientation="Vertical"
                                    VerticalAlignment="Center" Spacing="4">
                            <Button Content="T" Click="MovieMoveTop_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move to Top"/>
                            <Button Content="U" Click="MovieMoveUp_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move Up"/>
                            <Button Content="D" Click="MovieMoveDown_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move Down"/>
                            <Button Content="B" Click="MovieMoveBottom_Click"
                                    Width="32" Height="32"
                                    ToolTipService.ToolTip="Move to Bottom"/>
                        </StackPanel>
                    </Grid>

                    <!-- Filter row -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                        <TextBox x:Name="movieFilterBox"
                                 PlaceholderText="Filter..." Width="120"/>
                        <Button Content="Filter" Click="MovieFilterButton_Click"/>
                        <Button Content="Auto" Click="MovieAutoFilter_Click"/>
                        <TextBlock x:Name="movieFileCount" Text="0 file(s)"
                                   VerticalAlignment="Center" Margin="8,0"/>
                    </StackPanel>

                    <!-- Actions row -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4">
                        <CheckBox x:Name="movieAutoSort" Content="Auto Sort"
                                  Checked="MovieAutoSort_Changed"
                                  Unchecked="MovieAutoSort_Changed"/>
                        <Button Content="Sort" Click="MovieSort_Click"/>
                        <Button Content="+File" Click="MovieAddFile_Click"/>
                        <Button Content="+Folder" Click="MovieAddFolder_Click"/>
                        <Button Content="&#x2212;" Click="MovieRemoveEntry_Click"
                                Width="32" ToolTipService.ToolTip="Remove selected"/>
                        <Button Content="&#x2715;" Click="MovieClear_Click"
                                Width="32" ToolTipService.ToolTip="Clear all"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 1: Options -->
        <Border Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Options" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                <!-- Template -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Template" VerticalAlignment="Center"/>
                    <TextBox x:Name="renameTemplateTextBox" Grid.Column="1"/>
                </Grid>

                <!-- Specify options -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <CheckBox x:Name="optionSpecifySubtitleGroup"
                                  Content="Subtitle group"
                                  Checked="OptionSpecifySubtitleGroup_Changed"
                                  Unchecked="OptionSpecifySubtitleGroup_Changed"/>
                        <TextBox x:Name="optionSubtitleGroup" IsEnabled="False" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <CheckBox x:Name="optionSpecifyLanguage"
                                  Content="Language"
                                  Checked="OptionSpecifyLanguage_Changed"
                                  Unchecked="OptionSpecifyLanguage_Changed"/>
                        <TextBox x:Name="optionLanguage" IsEnabled="False" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <CheckBox x:Name="optionSpecifyExtension"
                                  Content="Extension"
                                  Checked="OptionSpecifyExtension_Changed"
                                  Unchecked="OptionSpecifyExtension_Changed"/>
                        <TextBox x:Name="optionExtension" IsEnabled="False" Width="120"/>
                    </StackPanel>
                </StackPanel>

                <!-- Move to movie folder + Display mode -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <CheckBox x:Name="optionMoveToMovieFolder" Content="Move to movie folder"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Display:" VerticalAlignment="Center"/>
                        <RadioButton x:Name="displayModeFullName" Content="Full Name"
                                     GroupName="DisplayMode"
                                     Checked="DisplayModeFullName_Checked"/>
                        <RadioButton x:Name="displayModeFileName" Content="File Name"
                                     GroupName="DisplayMode"
                                     Checked="DisplayModeFileName_Checked"/>
                        <RadioButton x:Name="displayModeDiscrepancyName" Content="Discrepancy"
                                     GroupName="DisplayMode"
                                     Checked="DisplayModeDiscrepancyName_Checked"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Bottom bar -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Auto-drop area -->
            <Border Grid.Column="0" AllowDrop="True"
                    DragOver="AutoDropPanel_DragOver" Drop="AutoDropPanel_Drop"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Width="150" Height="90" Padding="8">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <SymbolIcon Symbol="Import" HorizontalAlignment="Center"/>
                    <TextBlock Text="Drop Files Here" TextAlignment="Center"
                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Clear all button -->
            <Button Grid.Column="1" Click="DeleteAllPanel_Click"
                    Width="150" Height="90" CornerRadius="8">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <SymbolIcon Symbol="Delete"/>
                    <TextBlock Text="Clear All" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Checkboxes -->
            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                <CheckBox x:Name="optionClearSubtitlesAfterRename"
                          Content="Clear subtitles after rename"/>
                <CheckBox x:Name="optionClearMoviesAfterRename"
                          Content="Clear movies after rename"/>
                <CheckBox x:Name="optionAlwaysOnTop" Content="Always on top"
                          Checked="OptionAlwaysOnTop_Changed"
                          Unchecked="OptionAlwaysOnTop_Changed"/>
            </StackPanel>

            <!-- Preview / Rename buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Bottom">
                <Button Content="Preview" Click="PreviewButton_Click"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <Button Content="Rename" Click="RenameButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
